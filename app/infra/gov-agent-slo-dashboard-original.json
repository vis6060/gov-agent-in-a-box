{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": [
      {
        "type": "dashboard",
        "name": "Annotations & Alerts",
        "enable": true
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "iteration": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "title": "SLO Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "p95 latency (\\u00b1 5m)",
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "job:path:latency_p95_seconds:5m",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.15 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "p95 latency over time",
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 1 },
      "targets": [
        { "expr": "job:path:latency_p95_seconds:5m", "legendFormat": "p95 /v1/tasks", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "legend": { "showLegend": true }, "tooltip": { "mode": "single" } }
    },
    {
      "type": "stat",
      "title": "Success rate (\\u00b1 5m)",
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "targets": [
        { "expr": "job:path:success_rate:5m * 100", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "orange", "value": 98 },
              { "color": "green", "value": 99 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" }
    },
    {
      "type": "gauge",
      "title": "Short burn rate (5m / 1% budget)",
      "id": 5,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 5 },
      "targets": [
        { "expr": "slo:short_burn_rate", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 20,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 4 },
              { "color": "red", "value": 14 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "showThresholdLabels": false, "showThresholdMarkers": true }
    },
    {
      "type": "gauge",
      "title": "Long burn rate (1h / 1% budget)",
      "id": 6,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 5 },
      "targets": [
        { "expr": "slo:long_burn_rate", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 10,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 2 },
              { "color": "red", "value": 6 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "showThresholdLabels": false, "showThresholdMarkers": true }
    },
    {
      "type": "stat",
      "title": "Steady RPS (\\u00b1 5m)",
      "id": 7,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 5 },
      "targets": [
        { "expr": "job:path:req_rate_rps:5m", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Cache hit-rate (\\u00b1 5m)",
      "id": 8,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 5 },
      "targets": [
        { "expr": "rag:cache_hit_rate:5m * 100", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "orange", "value": 30 },
              { "color": "green", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "bargauge",
      "title": "Quota rejects by principal (\\u00b1 5m)",
      "id": 9,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 11 },
      "targets": [
        { "expr": "sum(rate(quota_rejects_total[5m])) by (principal)", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "options": { "displayMode": "basic", "orientation": "horizontal" }
    },
    {
      "type": "timeseries",
      "title": "API error rate by reason (\\u00b1 5m)",
      "id": 10,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 11 },
      "targets": [
        {
          "expr": "sum(rate(api_errors_total{path=\"/v1/tasks\"}[5m])) by (reason)",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "showLegend": true }, "tooltip": { "mode": "all" } }
    },
    {
      "type": "gauge",
      "title": "HITL queue size (by region)",
      "id": 11,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 17 },
      "targets": [
        { "expr": "hitl_queue_size", "legendFormat": "{{region}}", "refId": "A" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": false },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["gov-agent", "slo"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Gov-Agent SLOs & Ops",
  "version": 1,
  "weekStart": ""
}
